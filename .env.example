# -----------------------------------------------------------------------------
# DockerHub credentials (optional, needed to build images)
# -----------------------------------------------------------------------------
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# -----------------------------------------------------------------------------
# Solver agents + grading agents LLM backend
# -----------------------------------------------------------------------------

# Option A: External LiteLLM proxy (default, use --solver-backend proxy)
LITELLM_BASE_URL=https://your-litellm-proxy.example.com
LITELLM_API_KEY=sk-...

# Option B: Direct provider API keys (use --solver-backend direct or --grader-backend direct)
# PROVIDER_API_KEY=...

# -----------------------------------------------------------------------------
# ask_human LLM backend
# -----------------------------------------------------------------------------

# Option A: Local vLLM server (default, use --ask-human-backend vllm)
VLLM_BASE_URL=http://localhost:8808/v1
ASK_HUMAN_MODEL=casperhansen/llama-3.3-70b-instruct-awq

# Option B: LiteLLM proxy (use --ask-human-backend proxy)
# ASK_HUMAN_MODEL=gpt-4o-mini